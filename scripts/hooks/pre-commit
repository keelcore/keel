#!/usr/bin/env bash
# pre-commit
# Check that all staged Go files are gofmt -s clean.
# Check that all staged .md/.sh/.go files end with a trailing newline.
# Check that legal boilerplate files have not drifted.
# Regenerate schema.yaml if pkg/config/*.go changed.
# Run scripts/lint/fmt.sh or scripts/lint/newlines.sh --fix to repair, then re-stage.

# bash configuration:
# 1) Exit script if you try to use an uninitialized variable.
set -o nounset

# 2) Exit script if a statement returns a non-true return value.
set -o errexit

# 3) Use the error status of the first failure, rather than that of the last item in a pipeline.
set -o pipefail

# shellcheck source=../lib/paths.sh
source "$(git rev-parse --show-toplevel)/scripts/lib/paths.sh"

function main() {
  exec 5>&1
  validate_args "${@:-}"
  check_fmt
  check_newlines
  check_md_lint
  check_legal_drift
  check_schema
  check_helm
  check_ci_audit
}

function log() {
  local -r msg="${1:-}"
  printf '%s\n' "${msg}" | tee -a '/tmp/keel_hooks_pre_commit.log' >&5
}

function validate_args() {
  if [ "${#}" -gt 0 ] && [ -n "${1:-}" ]; then
    log '❌ Error: Unexpected arg'
    exit 1
  fi
}

function staged_text_files() {
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(md|sh|go|yml|yaml|toml|json)$|^\.gitignore$|^\.gitattributes$' \
    | filter_src || true
}

function check_newlines() {
  local files failed=0
  files="$(staged_text_files)"
  [ -z "${files}" ] && return 0
  while IFS= read -r f; do
    [ -s "${f}" ] || continue
    if [ "$(tail -c1 "${f}" | od -An -tx1 | tr -d ' \n')" != "0a" ]; then
      log "❌ Missing trailing newline: ${f}"
      failed=1
    fi
  done <<< "${files}"
  if [ "${failed}" -ne 0 ]; then
    log 'Run scripts/lint/newlines.sh --fix, review, and re-stage.'
    exit 1
  fi
}

function staged_md_files() {
  git diff --cached --name-only --diff-filter=ACMR | grep '\.md$' | filter_src || true
}

function check_md_lint() {
  local files
  files="$(staged_md_files)"
  [ -z "${files}" ] && return 0
  log '.md files changed — running markdownlint'
  printf '%s\n' "${files}" | xargs markdownlint --config \
    "$(git rev-parse --show-toplevel)/.markdownlint.json"
  log '✅ Markdown lint passed'
}

function check_legal_drift() {
  "$(git rev-parse --show-toplevel)/scripts/check-legal-drift.sh"
}

function staged_go_files() {
  git diff --cached --name-only --diff-filter=ACMR | grep '\.go$' | filter_src || true
}

function check_fmt() {
  local files unformatted
  files="$(staged_go_files)"
  [ -z "${files}" ] && return 0
  unformatted="$(printf '%s\n' "${files}" | xargs gofmt -l -s)"
  [ -z "${unformatted}" ] && return 0
  log '❌ Unformatted Go files:'
  while IFS= read -r f; do log "  ${f}"; done <<< "${unformatted}"
  log 'Run scripts/lint/fmt.sh, review, and re-stage.'
  exit 1
}

function staged_config_go() {
  git diff --cached --name-only --diff-filter=ACMR | grep '^pkg/config/.*\.go$' || true
}

function check_schema() {
  [ -n "$(staged_config_go)" ] || return 0
  log 'pkg/config/*.go changed — regenerating schema.yaml'
  bash scripts/release/gen-schema.sh
  if ! git diff --quiet pkg/config/schema.yaml; then
    git add pkg/config/schema.yaml
    log '✅ schema.yaml updated and staged'
  else
    log '✅ schema.yaml already up to date'
  fi
}

function staged_helm_files() {
  git diff --cached --name-only --diff-filter=ACMR | grep '^helm/' || true
}

function check_helm() {
  [ -n "$(staged_helm_files)" ] || return 0
  log 'helm/ changed — running helm lint'
  "$(git rev-parse --show-toplevel)/scripts/lint/helm.sh" \
  && "$(git rev-parse --show-toplevel)/scripts/lint/helm-validate.sh"
  log '✅ Helm lint passed'
}

function staged_ci_audit_files() {
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^\.github/workflows/|^scripts/.*\.sh$|^Makefile$' || true
}

function check_ci_audit() {
  [ -n "$(staged_ci_audit_files)" ] || return 0
  log 'CI-sensitive files changed — running Makefile audit'
  "$(git rev-parse --show-toplevel)/scripts/ci/audit-make-targets.sh"
  log '✅ CI audit passed'
}

main "${@:-}"
